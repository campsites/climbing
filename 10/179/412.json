a":"Q110690928","leisure":"sports_centre","name":"Vertical Hold","opening_hours":"Mo-Fr 09:00-22:00; Sa-Su 09:00-21:00","phone":"+1 858-748-9011","website":"https://www.verticalhold.com/"}},"10170111745":{"location":[32.9874968,-116.950089],"tp":"CL","tags":{"climbing:sport":"yes","climbing:toprope":"yes","climbing:traditional":"yes","name":"Ramona Wall","url":"https://www.dropbox.com/s/5kh4f6652ho312j/Ramona_Wall_Topo_02_18_2018.pdf?dl=0"}},"10170222417":{"location":[32.9873513,-116.94989],"tp":"CL","tags":{"climbing":"route_bottom","climbing:boulder":"no","climbing:sport":"no","climbing:toprope":"yes","climbing:traditional":"yes","name":"Updog","url":"https://www.mountainproject.com/route/109671162/updog"}},"10170499896":{"location":[32.9872516,-116.9500566],"tp":"CL","tags":{"climbing:bolts":"3","climbing:boulder":"no","climbing:chains":"2","climbing:sport":"yes","climbing:toprope":"yes","climbing:traditional":"yes","noname":"yes"}},"13441684674":{"location":[33.0109842,-116.9689311],"tp":"CL","tags":{"climbing":"route_bottom","climbing:grade:yds_class":"5.12c","climbing:length":"7","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Near-horizontal roof crack that goes from hands / fists to offwidth as you climb out.","image":"https://mountainproject.com/assets/photos/climb/117355281_large_1563124874.jpg","name":"Undertow","website":"https://www.mountainproject.com/route/111512774"}},"13441684833":{"location":[33.0104466,-116.9711268],"tp":"CL","tags":{"author":"FA British John","climbing":"route_bottom","climbing:aid":"yes","climbing:grade:aid":"A2","climbing:length":"12","climbing:sport":"no","climbing:trad":"yes","description":"Bill is the left (east) of the two aid climbs on the Ben & Bill boulder.","image":"https://mountainproject.com/assets/photos/climb/125780100_large_1710030656.jpg","name":"Bill","website":"https://www.mountainproject.com/route/125780076"}},"13441684836":{"location":[33.0104501,-116.9712051],"tp":"CL","tags":{"author":"FA British John","climbing":"route_bottom","climbing:aid":"yes","climbing:grade:aid":"A3","climbing:length":"9","climbing:sport":"no","climbing:trad":"yes","description":"Ben is the right (west) of the two aid climbs on the Ben & Bill boulder.","image":"https://mountainproject.com/assets/photos/climb/125780049_large_1710030222.jpg","name":"Ben","website":"https://www.mountainproject.com/route/125779994"}},"13441684874":{"location":[33.0101413,-116.9708892],"tp":"CL","tags":{"author":"FA Chancellor Roberts and Philipp Arndt","climbing":"route_bottom","climbing:bolts":"4","climbing:grade:aid":"A0","climbing:grade:yds_class":"5.10d","climbing:length":"12","climbing:sport":"yes","climbing:toprope":"yes","climbing:trad":"yes","description":"Very fun movement on positive edges. Eases up towards the top. To keep the grade in the 5.10 range you will need to aid through the first bolt, which can be clipped from the ground. Stepping into some slings will do. 4 bolts to a gear anchor.","image":"https://mountainproject.com/assets/photos/climb/200550480_large_1740900040.jpg","name":"Lethal Lemonade","website":"https://www.mountainproject.com/route/200550467"}},"13441684926":{"location":[33.0099354,-116.970598],"tp":"CL","tags":{"author":"FA Philipp Arndt","climbing":"route_bottom","climbing:grade:yds_class":"5.10b","climbing:length":"5","climbing:sport":"no","climbing:trad":"yes","description":"A short but sweet finger crack that goes surprisingly easy for how steeply overhung it is (~15 degrees). 2-bolt anchor with rap rings.","image":"https://mountainproject.com/assets/photos/climb/125778988_large_1710019167.jpg","name":"Trunk Tribute","website":"https://www.mountainproject.com/route/125778933"}},"13441684969":{"location":[33.0095626,-116.9705227],"tp":"CL","tags":{"author":"FA Michael Sandler and Philipp Arndt","climbing":"route_bottom","climbing:bolts":"3","climbing:grade:yds_class":"5.10c","climbing:length":"8","climbing:sport":"yes","climbing:toprope":"yes","climbing:trad":"no","description":"Thin and friction-y moves on a fairly low-angle slab. The crux is getting your feet onto the slopy hold on top of the small overlap. 2-bolt anchor, walk-off on the south side.","image":"https://mountainproject.com/assets/photos/climb/200550522_large_1740900647.jpg","name":"Dangermilk","website":"https://www.mountainproject.com/route/200550517"}},"13441684970":{"location":[33.009591,-116.9705212],"tp":"CL","tags":{"author":"FA Michael Sandler and Philipp Arndt","climbing":"route_bottom","climbing:bolts":"3","climbing:grade:yds_class":"5.10b","climbing:length":"11","climbing:sport":"yes","climbing:toprope":"yes","climbing:trad":"no","description":"Traversing slab route with mostly positive holds and and interesting sequence. The crux comes after the second bolt, where the right-trending foot ledge tapers out. 2-bolt anchor. Walk-off on the south side.","image":"https://mountainproject.com/assets/photos/climb/200550569_large_1740901891.jpg","name":"Forbidden Gatorade","website":"https://www.mountainproject.com/route/200550562"}},"13441685009":{"location":[33.0105964,-116.9679287],"tp":"CL","tags":{"author":"FA Rick Piggot","climbing":"route_bottom","climbing:grade:yds_class":"5.12a","climbing:length":"14","climbing:sport":"yes","climbing:toprope":"yes","climbing:trad":"yes","description":"Climb the obvious flake until it seams out, then switch to harder face climbing past bolts.","image":"https://mountainproject.com/assets/photos/climb/106954506_large_1494153920.jpg","name":"PhD","website":"https://www.mountainproject.com/route/106764430"}},"13441685468":{"location":[33.0075963,-116.9693741],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.11a","climbing:length":"6","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Overhanging jugs to layback on a seam. Reach move crux near the top. 2-bolt anchor for TR","image":"https://mountainproject.com/assets/photos/climb/120552042_large_1618529305.jpg","name":"The Cave","website":"https://www.mountainproject.com/route/105796678"}},"13441685502":{"location":[33.0073917,-116.9694542],"tp":"CL","tags":{"author":"FA Dick Cilley","climbing":"route_bottom","climbing:grade:yds_class":"5.11c","climbing:length":"5","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"no","description":"Steep lieback to a throw for the top.","image":"https://mountainproject.com/assets/photos/climb/109676278_large_1494359679.jpg","name":"Alcoa","website":"https://www.mountainproject.com/route/105796658"}},"13441685504":{"location":[33.0073987,-116.9694964],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.12a","climbing:length":"6","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"no","description":"Thin face up the center of the boulder.","image":"https://mountainproject.com/assets/photos/climb/107833769_large_1494214406.jpg","name":"Stairway to Heaven","website":"https://www.mountainproject.com/route/105796672"}},"13441685719":{"location":[33.0070219,-116.9712661],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.11a","climbing:length":"9","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"no","description":"Three routes (left: 5.11+, center: 5.11, right: 5.11-) all slabby face climbs on perfect rock, requiring delicate footwork. Toprope only.","image":"https://mountainproject.com/assets/photos/climb/107120495_large_1494167544.jpg","name":"Starface","website":"https://www.mountainproject.com/route/105846482"}},"13443119514":{"location":[33.0112829,-116.968965],"tp":"CL","tags":{"author":"FA Philipp Arndt, 2023","climbing":"route_bottom","climbing:bolt":"anchor","climbing:bolted":"yes","climbing:bolts":"3","climbing:grade:yds_class":"5.9","climbing:hazard:first_bolt_high":"yes","climbing:length":"13","climbing:sport":"yes","climbing:toprope":"yes","climbing:trad":"no","description":"Wide stemming chimney, 2-bolt anchor and 3 bolts for the lead. ","name":"The Learning Cave Chimney","website":"https://www.mountainproject.com/route/124290991","wikimedia_commons":"File:The Learning Cave Chimney.jpg"}},"13443254349":{"location":[33.0110246,-116.9709533],"tp":"CL","tags":{"author":"Philipp Arndt, Jan 2024","climbing":"route_bottom","climbing:grade:yds_class":"5.11-","climbing:length":"17","climbing:toprope":"yes","climbing:trad":"yes","description":"C4 cams size #0.5 to #3, with doubles #1-#2. Extra #2s probably won't go unused. Two-bolt anchor.Probably the longest continuous crack on the main hill. Nice-looking jams are so deep in the flare that it feels more like an offwidth. TR with directionals.","name":"Five-Nine Handcrack","website":"https://www.mountainproject.com/route/125779189","wikimedia_commons":"File:Five-Nine Handcrack.jpg"}},"13443711902":{"location":[33.0055952,-116.9658976],"tp":"CL","tags":{"author":"Royal Robbins, 1969","climbing":"route_bottom","climbing:grade:yds_class":"5.10a","climbing:length":"8","climbing:toprope":"yes","climbing:trad":"yes","description":"Most classic splitter crack at Woodson","name":"Robbins Crack","website":"https://www.mountainproject.com/route/105792316","wikimedia_commons":"File:Robbins Crack.jpg"}},"13444021648":{"location":[33.0113537,-116.9687864],"tp":"CL","tags":{"climbing":"route_bottom","climbing:grade:yds_class":"5.10","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Start by swinging to the obvious jug (or jumping if you are short), then make your way up the crack.","name":"Kaleidoskopik Karussell","website":"https://www.mountainproject.com/route/125662883"}},"13449240345":{"location":[33.0121203,-116.9743139],"tp":"CL","tags":{"climbing":"route_bottom","climbing:grade:yds_class":"5.10a","climbing:trad":"yes","description":"60 ft of finger crack liebacking to easier slab near the top. The crux is the first 15ft where the crack is thin and the wall is steep. Small cams (0.1-0.5) and a #2 for the top. 2 bolt anchor","name":"Victory at Sea","website":"https://www.mountainproject.com/route/124033085"}},"13449263021":{"location":[32.9992285,-116.9693529],"tp":"CL","tags":{"author":"Peter Gompper","climbing":"route_bottom","climbing:grade:yds_class":"5.11a/b","climbing:length":"14","climbing:trad":"yes","description":"Splitter tips crack with delicate feet. A Woodson classic, and long for the area. Small to medium cams and nuts, 2-bolt anchor.","name":"Cat Crack","website":"https://www.mountainproject.com/route/109868075"}},"13453103389":{"location":[33.0102333,-116.9698544],"tp":"CL","tags":{"author":"Philipp Arndt and Alexia Fabiani, May 2024","climbing":"route_bottom","climbing:bolts":"4","climbing:grade:yds_class":"5.10b","climbing:hazard:vegetation":"yes","climbing:inclination:slab":"yes","climbing:length":"13","climbing:sport":"yes","description":"Slabby route with a striking white dike running directly up the middle of the face. Interesting moves on mostly flakey crimps. 4 bolts and 2-bolt anchor. ","name":"Plutonacious","website":"https://www.mountainproject.com/route/126192494","wikimedia_commons":"File:Plutonacious Mount Woodson.jpg","wikimedia_commons:2":"File:Plutonacious Boulder, Mount Woodson.jpg","wikimedia_commons:2:path":"0.677,0.958|0.69,0.865|0.691,0.794|0.681,0.7|0.656,0.604|0.672,0.537|0.718,0.475|0.744,0.375|0.755,0.288|0.755,0.213|0.771,0.109|0.796,0.053"}},"13461578953":{"location":[33.0106335,-116.9713922],"tp":"CL","tags":{"author":"project","climbing":"route_bottom","climbing:grade:yds_class":"5.13-","climbing:length":"16","climbing:sport":"no","climbing:trad":"yes","description":"No known ascents as of Dec 2025. Long, right-leaning, overhung crack. Offwidth to flared tips (crux) to mostly fingers. Seems to stay wet for multiple days after it rains.","name":"Hard And Soul (project)","website":"https://www.mountainproject.com/route/125779535"}},"13461578954":{"location":[33.010624,-116.9713054],"tp":"CL","tags":{"climbing":"route_bottom","climbing:grade:yds_class":"5.10b","climbing:length":"12","climbing:sport":"no","climbing:trad":"yes","description":"Surprisingly fun and geometric climbing leads to a distinct offwidth crux. Watch out for poison oak, it might sprout out of the crack again.","name":"Battle of Urushiol","website":"https://www.mountainproject.com/route/126510376"}},"13461578956":{"location":[33.0112702,-116.9690891],"tp":"CL","tags":{"climbing":"route_bottom","climbing:grade:yds_class":"5.6","climbing:length":"12","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Toprope or solo. 2-bolt anchor.","name":"Shallow Learning Cave"}},"13461578958":{"location":[33.011067,-116.9695676],"tp":"CL","tags":{"climbing":"route_bottom","climbing:grade:yds_class":"5.7","climbing:length":"8","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Low-angle less than vertical crack in a dihedral. Starts with hands and widens all the way to offwidth near the top. Watch out for poison oak.","name":"Pac-Man"}},"13461578959":{"location":[33.0092533,-116.9735344],"tp":"CL","tags":{"climbing":"route_bottom","climbing:grade:yds_class":"5.10b/c","climbing:length":"8","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Hands to offwidth, slightly overhung. Woodson classic.","name":"Crucible","website":"https://www.mountainproject.com/route/105803108"}},"13461578960":{"location":[33.0098074,-116.9688146],"tp":"CL","tags":{"author":"unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.9","climbing:length":"11","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Somewhat awkward start to an awesome splitter hand crack. Woodson classic.","name":"Out Of Sight","website":"https://www.mountainproject.com/route/105932005"}},"13461578961":{"location":[33.0077572,-116.9675823],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.9","climbing:length":"12","climbing:sport":"no","climbing:trad":"yes","description":"The name says it all. A few grunty offwidth moves to an awesome chimney solo. No bolts, but the solo is secure. A Woodson classic.","image":"https://mountainproject.com/assets/photos/climb/126447290_large_1719612957.jpg","name":"Big Grunt","website":"https://www.mountainproject.com/route/105941695"}},"13461578962":{"location":[33.0056857,-116.9696093],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.10a","climbing:length":"8","climbing:sport":"no","climbing:trad":"yes","description":"Perfect dihedral with a splitter wide hands crack to a mantle at the top. A Woodson classic.","name":"Rockwork Orange","website":"https://www.mountainproject.com/route/105792831"}},"13461578963":{"location":[33.0102662,-116.9682729],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.8","climbing:length":"15","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Good hand crack on a dihedral leads to off width as you climb higher. Bolted anchor.","image":"https://mountainproject.com/assets/photos/climb/113723612_large_1508408138.jpg","name":"Fake Phantom Crack","website":"https://www.mountainproject.com/route/105931357"}},"13461578964":{"location":[33.0058094,-116.9674458],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:boulder":"yes","climbing:grade:hueco":"V1","climbing:grade:yds_class":"5.11a","climbing:length":"5","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Splitter fingers to ringlocks crack. A short Woodson classic.","name":"Jaws","website":"https://www.mountainproject.com/route/105791650"}},"13461578965":{"location":[33.0052844,-116.9665143],"tp":"CL","tags":{"author":"FA Bill Ramsey","climbing":"route_bottom","climbing:grade:yds_class":"5.11c","climbing:length":"11","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"no","image":"https://mountainproject.com/assets/photos/climb/118974455_large_1591135260.jpg","name":"Uncertainty Principle","website":"https://www.mountainproject.com/route/105796563"}},"13461578966":{"location":[33.0080858,-116.9682906],"tp":"CL","tags":{"author":"FA Greg Cameron","climbing":"route_bottom","climbing:grade:yds_class":"5.11+","climbing:length":"7","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Two cruxes, one knee/calf lock offwidth at the bottom, and another bouldery one at the top. A Woodson classic.","image":"https://mountainproject.com/assets/photos/climb/107293123_large_1494179381.jpg","name":"Mother Superior","website":"https://www.mountainproject.com/route/105796521"}},"13461578967":{"location":[33.0070213,-116.9645938],"tp":"CL","tags":{"climbing":"route_bottom","climbing:grade:yds_class":"5.11c","climbing:length":"9","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Thin splitter crack up a less than vertical face, widening towards the top. Thin tips at the start are the crux. A Woodson classic.","image":"https://mountainproject.com/assets/photos/climb/119621596_large_1601067588.jpg","name":"Hard as Nails","website":"https://www.mountainproject.com/route/106118502"}},"13461609921":{"location":[33.0088566,-116.96762],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.7","climbing:length":"6","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Splitter tight hand crack on less than vertical rock. Everyone's first trad lead at Woodson. Gear anchor -- keep your rope out of the crack!","image":"https://mountainproject.com/assets/photos/climb/123543702_large_1670562983.jpg","name":"Elsa's Crack","website":"https://www.mountainproject.com/route/105820087"}},"13461708953":{"location":[33.0076539,-116.9676765],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.7","climbing:length":"11","climbing:sport":"no","climbing:trad":"yes","description":"Roadside moderate flared fist crack / offwidth. 2-bolt anchor. Need to lead first to set a toprope.","image":"https://mountainproject.com/assets/photos/climb/107071189_large_1494163654.jpg","name":"Poison Oak Crack","website":"https://www.mountainproject.com/route/105792854"}},"13461708985":{"location":[33.0075205,-116.9825254],"tp":"CL","tags":{"author":"Yoav Altman (TR), Erik Roed (lead)","climbing":"route_bottom","climbing:grade:yds_class":"5.10a","climbing:length":"9","climbing:sport":"no","climbing:trad":"yes","description":"Splitter crack -- mostly sweet finger locks, with the crux near the top, as the crack widens slightly and steepens to just past vertical. Gear anchor.","image":"https://mountainproject.com/assets/photos/climb/109830815_large_1494363784.jpg","name":"Yoav Crack","website":"https://www.mountainproject.com/route/109830357"}},"13461720037":{"location":[33.0040178,-116.966771],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.8","climbing:length":"7","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Nice moderate hands to offwidth crack (BD C4 #2-#6). Great for learning some OW technique.","image":"https://mountainproject.com/assets/photos/climb/106358301_large_1494101333.jpg","name":"Sickle Crack","website":"https://www.mountainproject.com/route/105791745"}},"13461741130":{"location":[32.9977835,-116.9684432],"tp":"CL","tags":{"ford":"yes"}},"13519007703":{"location":[33.0059343,-116.9681656],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:boulder":"yes","climbing:grade:hueco":"V7","climbing:length":"3","climbing:sport":"no","climbing:trad":"no","description":"Woodson's most classic pure boulder problem. In the little shaded cave-like area on the inside of the switchback. Hand traverse from the left to right, to a big exit move out right. Hard.","image":"https://mountainproject.com/assets/photos/climb/116496007_large_1548802915.jpg","name":"The Fake Eppulator","website":"https://www.mountainproject.com/route/105846414"}},"13519007719":{"location":[33.0083721,-116.9691362],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.10d","climbing:length":"7","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Great thin finger crack. 2-bolt anchor for TR and lowering.","image":"https://mountainproject.com/assets/photos/climb/109676282_large_1494359680.jpg","name":"Digit's Delight","website":"https://www.mountainproject.com/route/105796703"}},"13519007724":{"location":[33.0055684,-116.9691502],"tp":"CL","tags":{"author":"FA unknown","climbing":"route_bottom","climbing:grade:yds_class":"5.8","climbing:length":"11","climbing:sport":"no","climbing:toprope":"yes","climbing:trad":"yes","description":"Fun finger crack in a low-angle corner. Gear anchor.","image":"https://mountainproject.com/assets/photos/climb/107053258_medium_1494162254.jpg","name":"Milkbar","website":"https://www.mountainproject.com/route/105793003"}}}